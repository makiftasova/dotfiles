[Unit]
Description=VPN Isolated GUI App: %i
After=graphical.target
After=wg-vpn-start@wg0.service
Requires=wg-vpn-start@wg0.service

[Service]
Type=simple
# %i represents the string after the @ (e.g., 'firefox')
# %I is the same but unescaped (better for paths/args)
ExecStart=/usr/bin/sudo /usr/local/bin/wg_netns_run stvpn %I
Restart=on-failure
# Ensure the app doesn't hang on logout
KillMode=process

[Install]
WantedBy=graphical-session.target
